# ========= CONFIGURAÇÕES GERAIS =========
# Defina um ambiente seguro e os domínios
NODE_ENV=production

# ========= FRONTEND (Next.js) =========
NEXT_PUBLIC_API_URL=https://webhook.saito.app.br
NEXT_PUBLIC_BACKEND_URL=https://webhook.saito.app.br
NEXT_PUBLIC_SUPABASE_URL=YOUR_SUPABASE_URL
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# ========= BACKEND (Fastify) =========
PORT=3001
SUPABASE_URL=YOUR_SUPABASE_URL
SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
SUPABASE_SERVICE_ROLE_KEY=YOUR_SUPABASE_SERVICE_ROLE_KEY
WEBHOOK_URL=https://webhook.saito.app.br/webhooks/evolution
OPENAI_API_KEY=YOUR_OPENAI_API_KEY
STRIPE_SECRET_KEY=YOUR_STRIPE_SECRET_KEY
STRIPE_WEBHOOK_SECRET=YOUR_STRIPE_WEBHOOK_SECRET

# Conexão interna do Backend com os outros containers
REDIS_HOST=redis
REDIS_PORT=6379
EVOLUTION_URL=http://evolution-api:8080
EVOLUTION_GLOBAL_KEY=SUA_CHAVE_GLOBAL_EVOLUTION_AQUI

# ========= EVOLUTION API =========
AUTHENTICATION_TYPE=apikey
AUTHENTICATION_API_KEY=SUA_CHAVE_GLOBAL_EVOLUTION_AQUI # Mantenha a mesma chave de cima
AUTHENTICATION_EXPOSE_IN_FETCH_INSTANCES=true
CACHE_REDIS_ENABLED=true
CACHE_REDIS_URI=redis://redis:6379/1
CACHE_REDIS_PREFIX_KEY=evolution
CACHE_REDIS_SAVE_INSTANCES=false
CACHE_LOCAL_ENABLED=false
REDIS_ENABLED=true
REDIS_URI=redis://redis:6379/1
REDIS_PREFIX_KEY=evolution
DATABASE_PROVIDER=postgresql
DATABASE_CONNECTION_URI=postgres://saito_user:saito_password@postgres:5432/evolution
DATABASE_CONNECTION_CLIENT_NAME=evolution_api
WEBSOCKET_ENABLED=false

# ========= POSTGRES (Banco Local DB) =========
POSTGRES_USER=saito_user
POSTGRES_PASSWORD=saito_password
POSTGRES_DB=evolution
